# Copy this file to .env before running docker compose.

# App runtime
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:4000

# PostgreSQL
POSTGRES_DB=products_db
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
